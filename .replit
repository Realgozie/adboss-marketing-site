entrypoint = "server.js"
modules = ["nodejs-22"]
hidden = [".config", "package-lock.json"]

[deployment]
run = ["node", "server.js"]
deploymentTarget = "autoscale"
onBoot = "npm run build && node server.js"
build = ["npm", "run", "build"]

[[ports]]
localPort = 3002
externalPort = 3002

[[ports]]
localPort = 4173
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Web Server"

[[workflows.workflow]]
name = "Web Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node server.js"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[nix]
channel = "stable-25_05"
packages = ["tree", "opensshWithKerberos"]

[userenv]

[userenv.shared]
ADMIN_EMAIL = "info.adboss@gmail.com"
