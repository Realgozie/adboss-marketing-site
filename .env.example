# AdBOSS — Environment Variables
# ================================
# Copy this file to .env and fill in your values.
# Works with any platform: VS Code, Railway, Render, Heroku,
# DigitalOcean App Platform, Fly.io, Vercel, etc.
#
# Locally: create a .env file in the project root and run:
#   node server.js
#
# On any cloud host: set these in the platform's dashboard
# (Environment Variables / Config Vars / Secrets section).

# ── Server ──────────────────────────────────────────────────
PORT=5000

# ── Stripe Payments ─────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Get this from https://dashboard.stripe.com/webhooks
# Point the webhook at: https://yourdomain.com/api/stripe/webhook
# Listen for: checkout.session.completed, customer.subscription.deleted, customer.subscription.updated
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — run the seed script to generate these:
#   node scripts/seed-stripe-products.js
STRIPE_PRICE_GROWTH_MONTHLY=price_...
STRIPE_PRICE_GROWTH_YEARLY=price_...
STRIPE_PRICE_SCALE_MONTHLY=price_...
STRIPE_PRICE_SCALE_YEARLY=price_...

# ── Email (optional but recommended) ────────────────────────
# Gmail: generate an App Password at
# myaccount.google.com → Security → App passwords
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password

# ── Domain ──────────────────────────────────────────────────
# Your production domain (no https://) — used in email links
CUSTOM_DOMAIN=yourdomain.com
